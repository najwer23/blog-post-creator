{
  "name": "blog-post-creator",
  "version": "1.0.0",
  "keywords": [
    "react",
    "gh-pages",
    "typescript",
    "vite",
    "vitest",
    "css modules",
    "front-end",
    "yarn",
    "pwa"
  ],
  "homepage": "https://najwer23.github.io/blog-post-creator/",
  "type": "module",
  "scripts": {
    "bench": "vitest bench",
    "build": "tsc --build --clean && vite build",
    "deploy": "yarn run build && gh-pages -d build && rimraf build",
    "format": "yarn exec biome check --write",
    "god": "ncu -u && yarn install && yarn run start",
    "preview": "yarn build && vite preview --open --host",
    "start": "vite --open --host",
    "test": "vitest",
    "sort": "npx sort-package-json"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.11",
    "@tanstack/react-query": "^5.99.0",
    "@tanstack/react-query-persist-client": "^5.99.0",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "gh-pages": "^6.3.0",
    "najwer23morsels": "^0.22.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-router-dom": "^7.14.1",
    "rimraf": "^6.1.3",
    "typescript": "^6.0.2",
    "vite": "^8.0.8",
    "vite-plugin-pwa": "^1.2.0"
  },
  "packageManager": "yarn@4.13.0",
  "dependencies": {
    "zustand": "^5.0.12"
  }
}
